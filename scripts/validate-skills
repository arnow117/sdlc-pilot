#!/usr/bin/env bash
# sdlc-pilot з»“жһ„ lint вҖ”вҖ” еҸҜйҮҚеӨҚеӣһеҪ’жөӢиҜ•(зәҜ shell,ж— дҫқиө–)гҖӮ
# жЈҖжҹҘ:в‘  жҜҸдёӘ SKILL.md жңүеҗҲжі• frontmatter;в‘Ў и§’иүІеҗҚвҶ”ж–Үд»¶вҶ”еӯ—е…ёдёҖиҮҙ;
#       в‘ў validate жЁЎејҸеҗҚвҶ”ж–Үд»¶вҶ”еӯ—е…ёдёҖиҮҙ;в‘Ј е…ій”®е…ұдә«ж–Үд»¶еӯҳеңЁгҖӮ
# з”Ёжі•:bash scripts/validate-skills   (commit еүҚеҝ…и·‘;йҖҖеҮәз Ғ 0=йҖҡиҝҮ)
set -u
cd "$(dirname "$0")/.." || exit 2
ROOT="skills"; REF="$ROOT/sdlc/references"
fail=0
err(){ echo "  вң— $1"; fail=$((fail+1)); }
ok(){ echo "  вң“ $1"; }

echo "== 1. е…ій”®е…ұдә«ж–Үд»¶/зӣ®еҪ• =="
for p in "$REF/role-routing.md" "$REF/distillation-loop.md" "$REF/roles" "$REF/validate-modes" "$REF/templates/STATE.md" "$REF/templates/PROFILE.md"; do
  [ -e "$p" ] && ok "$p" || err "зјәеӨұ:$p"
done

echo "== 2. жҜҸдёӘ SKILL.md frontmatter(name + description) =="
for f in "$ROOT"/*/SKILL.md; do
  head -15 "$f" | grep -qE '^name:' || err "$f зјә name:"
  head -15 "$f" | grep -qE '^description:' || err "$f зјә description:"
done
[ $fail -eq 0 ] && ok "е…ЁйғЁ SKILL.md frontmatter еҗҲжі•"

echo "== 3. и§’иүІеҚЎ:ж–Үд»¶ вҶ” role-routing еӯ—е…ё вҶ” STATE жЁЎжқҝ =="
for rf in "$REF"/roles/*.md; do
  r="$(basename "$rf" .md)"
  grep -q "$r" "$REF/role-routing.md" || err "и§’иүІ '$r' жңӘеңЁ role-routing.md еҮәзҺ°(еӯ—е…ё/и§„еҲҷжјҸзҷ»и®°)"
  grep -q "$r" "$REF/templates/STATE.md" || err "и§’иүІ '$r' жңӘеңЁ STATE жЁЎжқҝеҸ–еҖјеӯ—е…ё"
done
ok "и§’иүІеҚЎдәӨеҸүеј•з”ЁжЈҖжҹҘе®ҢжҲҗ($(ls "$REF"/roles/*.md | wc -l | tr -d ' ') дёӘ)"

echo "== 4. validate жЁЎејҸ:ж–Үд»¶ вҶ” role-routing вҶ” sdlc-validate =="
for mf in "$REF"/validate-modes/*.md; do
  m="$(basename "$mf" .md)"
  grep -q "$m" "$REF/role-routing.md" || err "жЁЎејҸ '$m' жңӘеңЁ role-routing.md"
  grep -q "$m" "$ROOT/sdlc-validate/SKILL.md" || err "жЁЎејҸ '$m' жңӘиў« sdlc-validate еј•з”Ё"
done
ok "validate жЁЎејҸдәӨеҸүеј•з”ЁжЈҖжҹҘе®ҢжҲҗ($(ls "$REF"/validate-modes/*.md | wc -l | tr -d ' ') дёӘ)"

echo "== 5. еҸҜз§»жӨҚиҮӘжЈҖ:жөҒзЁӢ skill дёҚеҫ—зЎ¬дҫқиө– Claude дё“еұһе·Ҙе…· =="
for f in "$ROOT"/*/SKILL.md; do
  # е…Ғи®ёеҮәзҺ°еңЁ"йҷҚзә§/дёҚдҫқиө–"иҜӯеўғ;иҝҷйҮҢеҸӘзІ—жҹҘжҳҜеҗҰе®Ңе…ЁжІЎжҸҗйҷҚзә§еҚҙзЎ¬з”Ё AskUserQuestion
  if grep -q "AskUserQuestion" "$f" && ! grep -q "text_mode" "$f"; then
    err "$f жҸҗеҲ° AskUserQuestion дҪҶж—  text_mode йҷҚзә§(иҝқеҸҚеҸҜз§»жӨҚй“ҒеҫӢ)"
  fi
done
[ $fail -eq 0 ] && ok "еҸҜз§»жӨҚиҮӘжЈҖйҖҡиҝҮ"

echo
if [ $fail -eq 0 ]; then echo "RESULT: PASS вң…"; exit 0
else echo "RESULT: $fail йЎ№дёҚдёҖиҮҙ вқҢ(дҝ®е®ҢеҶҚ commit)"; exit 1; fi
